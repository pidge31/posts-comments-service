scalar Time

directive @goField(forceResolver: Boolean, name: String) on INPUT_FIELD_DEFINITION | FIELD_DEFINITION

type Post {
  id: ID!
  authorID: String!
  title: String!
  body: String!
  commentsEnabled: Boolean!
  createdAt: Time!
  updatedAt: Time!

  comments(first: Int, after: String): CommentConnection! @goField(forceResolver: true)
}

type PostPreview {
  id: ID!
  authorID: String!
  title: String!
  excerpt: String!
  commentsEnabled: Boolean!
  createdAt: Time!
  updatedAt: Time!
}

type PostPreviewEdge {
  cursor: String!
  node: PostPreview!
}

type PostPreviewConnection {
  edges: [PostPreviewEdge!]!
  pageInfo: PageInfo!
}

type Comment {
  id: ID!
  postID: ID!
  parentID: ID
  authorID: String!
  text: String!
  createdAt: Time!
  isDeleted: Boolean!

  replies(first: Int, after: String): CommentConnection! @goField(forceResolver: true)
}

type PageInfo {
  endCursor: String
  hasNextPage: Boolean!
}

type PostEdge {
  cursor: String!
  node: Post!
}

type PostConnection {
  edges: [PostEdge!]!
  pageInfo: PageInfo!
}

type CommentEdge {
  cursor: String!
  node: Comment!
}

type CommentConnection {
  edges: [CommentEdge!]!
  pageInfo: PageInfo!
}

input CreatePostInput {
  authorID: String!
  title: String!
  body: String!
  commentsEnabled: Boolean!
}

input AddCommentInput {
  postID: ID!
  parentID: ID
  authorID: String!
  text: String!
}

type Query {
  posts(first: Int, after: String): PostPreviewConnection!
  post(id: ID!): Post
  comment(id: ID!): Comment
}

type Mutation {
  createPost(input: CreatePostInput!): Post!
  deletePost(postID: ID!, authorID: String!): Boolean!
  addComment(input: AddCommentInput!): Comment!
  deleteComment(commentID: ID!, authorID: String!): Boolean!
  setPostCommentsEnabled(postID: ID!, authorID: String!, enabled: Boolean!): Post!
}

type Subscription {
  commentAdded(postID: ID!): Comment!
}
